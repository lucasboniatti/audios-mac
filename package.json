{
  "name": "@audioflow/design-system",
  "version": "1.0.0",
  "description": "AudioFlow Design System - Component library and design tokens",
  "main": "frontend/components/index.tsx",
  "scripts": {
    "tokens:build": "node scripts/build-tokens.js",
    "tokens:validate": "node -e \"require('./design-tokens/tokens.json')\"",
    "lint": "node scripts/lint-frontend-css.mjs",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "npx tsc --project tsconfig.json",
    "test": "node --test tests/frontend-quality.test.mjs",
    "test:a11y": "echo \"Accessibility tests - implement with axe-core\"",
    "build": "npm run tokens:build && npm --prefix frontend run build:css",
    "storybook": "npm run build && STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 -c .storybook",
    "storybook:build": "npm run build && STORYBOOK_DISABLE_TELEMETRY=1 CI=1 storybook build -c .storybook -o storybook-static"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "component-library",
    "audioflow",
    "react",
    "swift",
    "swiftui"
  ],
  "author": "AudioFlow Team",
  "license": "MIT",
  "devDependencies": {
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/addon-links": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-webpack5": "8.6.14",
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-loader": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "js-yaml": "^4.1.0",
    "postcss": "^8.4.38",
    "postcss-scss": "^4.0.9",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "8.6.14",
    "stylelint": "^16.2.1",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-no-px": "^1.0.1",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/audioflow/design-system.git"
  },
  "bugs": {
    "url": "https://github.com/audioflow/design-system/issues"
  },
  "homepage": "https://audioflow.app/design-system"
}
